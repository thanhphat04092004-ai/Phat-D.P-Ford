<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landing Page Xe Ô Tô</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-900">

  <!-- Hero Section -->
  <section class="bg-black text-white">
    <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-5xl font-bold leading-tight mb-6">
          Khám Phá Dòng Xe Ô Tô Đẳng Cấp
        </h1>
        <p class="text-lg text-gray-300 mb-8">
          Chuyên cung cấp các dòng xe sang, hiện đại với giá tốt nhất thị trường.
          Trải nghiệm lái thử miễn phí ngay hôm nay.
        </p>

        <div class="flex gap-4">
          <button class="bg-red-600 hover:bg-red-700 px-6 py-3 rounded-2xl text-lg font-semibold shadow-lg transition">
            Đăng Ký Tư Vấn
          </button>

          <button class="border border-white px-6 py-3 rounded-2xl text-lg hover:bg-white hover:text-black transition">
            Xem Bộ Sưu Tập
          </button>
        </div>
      </div>

      <div>
        <img
          src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1600&auto=format&fit=crop"
          alt="Car"
          class="rounded-3xl shadow-2xl"
        />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <h2 class="text-4xl font-bold text-center mb-14">
      Vì Sao Chọn Chúng Tôi?
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white rounded-3xl p-8 shadow-lg">
        <div class="text-5xl mb-4">🚗</div>
        <h3 class="text-2xl font-semibold mb-3">Xe Đa Dạng</h3>
        <p class="text-gray-600">
          Nhiều mẫu xe từ sedan, SUV đến xe thể thao cao cấp.
        </p>
      </div>

      <div class="bg-white rounded-3xl p-8 shadow-lg">
        <div class="text-5xl mb-4">💰</div>
        <h3 class="text-2xl font-semibold mb-3">Giá Tốt</h3>
        <p class="text-gray-600">
          Chính sách giá cạnh tranh cùng nhiều ưu đãi hấp dẫn.
        </p>
      </div>

      <div class="bg-white rounded-3xl p-8 shadow-lg">
        <div class="text-5xl mb-4">⭐</div>
        <h3 class="text-2xl font-semibold mb-3">Dịch Vụ Cao Cấp</h3>
        <p class="text-gray-600">
          Hỗ trợ khách hàng 24/7 và bảo hành chuyên nghiệp.
        </p>
      </div>
    </div>
  </section>

  <!-- Car Collection -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-14">
        Mẫu Xe Nổi Bật
      </h2>

      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-gray-50 rounded-3xl overflow-hidden shadow-lg hover:scale-105 transition">
          <img
            src="https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=1200&auto=format&fit=crop"
            alt="Mercedes"
            class="h-56 w-full object-cover"
          />

          <div class="p-6">
            <h3 class="text-2xl font-semibold mb-2">Mercedes-Benz C300</h3>
            <p class="text-red-600 font-bold text-xl mb-4">1.8 tỷ VNĐ</p>
            <button class="w-full bg-black text-white py-3 rounded-2xl hover:bg-gray-800 transition">
              Xem Chi Tiết
            </button>
          </div>
        </div>

        <div class="bg-gray-50 rounded-3xl overflow-hidden shadow-lg hover:scale-105 transition">
          <img
            src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1200&auto=format&fit=crop"
            alt="BMW"
            class="h-56 w-full object-cover"
          />

          <div class="p-6">
            <h3 class="text-2xl font-semibold mb-2">BMW X5</h3>
            <p class="text-red-600 font-bold text-xl mb-4">3.2 tỷ VNĐ</p>
            <button class="w-full bg-black text-white py-3 rounded-2xl hover:bg-gray-800 transition">
              Xem Chi Tiết
            </button>
          </div>
        </div>

        <div class="bg-gray-50 rounded-3xl overflow-hidden shadow-lg hover:scale-105 transition">
          <img
            src="https://images.unsplash.com/photo-1502877338535-766e1452684a?q=80&w=1200&auto=format&fit=crop"
            alt="Audi"
            class="h-56 w-full object-cover"
          />

          <div class="p-6">
            <h3 class="text-2xl font-semibold mb-2">Audi A6</h3>
            <p class="text-red-600 font-bold text-xl mb-4">2.4 tỷ VNĐ</p>
            <button class="w-full bg-black text-white py-3 rounded-2xl hover:bg-gray-800 transition">
              Xem Chi Tiết
            </button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="bg-red-600 text-white py-20">
    <div class="max-w-4xl mx-auto text-center px-6">
      <h2 class="text-4xl font-bold mb-6">
        Đăng Ký Lái Thử Ngay Hôm Nay
      </h2>

      <p class="text-lg mb-8 text-red-100">
        Để lại thông tin để nhận tư vấn miễn phí và ưu đãi đặc biệt.
      </p>

      <form class="grid md:grid-cols-3 gap-4">
        <input
          type="text"
          placeholder="Họ và tên"
          class="px-4 py-3 rounded-2xl text-black"
        />

        <input
          type="tel"
          placeholder="Số điện thoại"
          class="px-4 py-3 rounded-2xl text-black"
        />

        <button class="bg-black hover:bg-gray-900 rounded-2xl px-6 py-3 font-semibold transition">
          Gửi Thông Tin
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black text-gray-400 text-center py-6">
    © 2026 Auto Luxury Việt Nam. All rights reserved.
  </footer>

</body>
</html>
